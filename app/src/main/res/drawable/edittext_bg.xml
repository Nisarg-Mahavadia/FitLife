<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- White background -->
    <solid android:color="#FFFFFF"/>

    <!-- Soft professional muted blue border -->
    <stroke
        android:width="1.6dp"
        android:color="#4A6FD9"/>

    <!-- Smooth modern rounded corners -->
    <corners android:radius="14dp"/>

    <!-- Better inner spacing -->
    <padding
        android:left="16dp"
        android:top="12dp"
        android:right="16dp"
        android:bottom="12dp"/>

</shape>
