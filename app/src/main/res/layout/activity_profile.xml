<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/backgroundLight">

    <include layout="@layout/toolbar_simple"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="24dp">

            <!-- CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/white_card_bg"
                android:padding="24dp"
                android:elevation="6dp">

                <!-- PROFILE IMAGE -->
                <ImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:src="@drawable/profile_user"
                    android:layout_marginBottom="16dp"/>

                <!-- NAME -->
                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <!-- DETAILS SECTION -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- EMAIL LABEL -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email:"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#212121"/>

                    <!-- EMAIL VALUE -->
                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="#616161"
                        android:layout_marginBottom="12dp"/>

                    <!-- GENDER -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gender:"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#212121"/>

                    <TextView
                        android:id="@+id/tvGender"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="#616161"
                        android:layout_marginBottom="12dp"/>

                    <!-- AGE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Age:"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#212121"/>

                    <TextView
                        android:id="@+id/tvAge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="#616161"
                        android:layout_marginBottom="12dp"/>

                    <!-- BMI -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BMI:"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#212121"/>

                    <TextView
                        android:id="@+id/tvBmi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="#616161"/>
                </LinearLayout>

                <!-- BUTTONS -->
                <Button
                    android:id="@+id/btnEditProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="EDIT PROFILE"
                    android:background="@drawable/rounded_orange_button"                    android:textColor="@android:color/white"
                    android:layout_marginTop="20dp"/>

                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LOGOUT"
                    android:background="@drawable/rounded_blue_button"                    android:textColor="@android:color/white"
                    android:layout_marginTop="12dp"/>

                <Button
                    android:id="@+id/btnDeleteProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DELETE PROFILE"
                    android:background="@drawable/rounded_red_button"                    android:textColor="@android:color/white"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
